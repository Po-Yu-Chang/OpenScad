{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencad.dev/schemas/feature.schema.json",
  "title": "OpenCad Feature Graph File",
  "description": "features.json——Feature Graph 的持久化格式，包含 schema_version 與特徵陣列",
  "type": "object",
  "required": ["schema_version", "features"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "features": {
      "type": "array",
      "items": { "$ref": "#/definitions/feature" }
    },
    "bodies": {
      "type": "array",
      "description": "多實體支援（v2）——每個 body 一個 id/name/material/appearance",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "material": { "type": "string" },
          "appearance": {}
        },
        "required": ["id"]
      }
    },
    "reference_geometry": {
      "type": "array",
      "description": "WP1-3 基準幾何陣列（datum plane/axis/point）——WP-S1 修復：原本只在\ndefinitions 定義單一項目的形狀，從未被頂層 $ref 引用，與實際存檔格式\n（cad_worker/feature_graph.py 的 to_dict()）對不上，已接上。",
      "items": { "$ref": "#/definitions/reference_geometry" }
    },
    "rollback_position": {
      "type": ["integer", "null"],
      "description": "回溯位置（v2）——null 表示未回溯，顯示到最新特徵"
    },
    "global_variables": {
      "type": "array",
      "description": "全域變數（Phase 2 WP2-1 預留欄位，目前存但不求值）",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "expression": { "type": "string" },
          "unit": { "type": "string" }
        }
      }
    },
    "configurations": {
      "type": "array",
      "description": "設計組態（Phase 2 預留欄位）"
    },
    "custom_properties": {
      "type": "object",
      "description": "自訂屬性（material/描述等中繼資料）"
    }
  },
  "definitions": {
    "parameter_value": {
      "oneOf": [
        { "type": "number" },
        {
          "type": "object",
          "properties": {
            "value": { "type": "number" },
            "unit": {
              "type": "string",
              "enum": ["mm", "cm", "m", "inch", "deg", "rad"]
            }
          },
          "required": ["value", "unit"]
        },
        { "type": "string" },
        { "type": "boolean" },
        { "type": "array" }
      ]
    },
    "sketch_entity": {
      "type": "object",
      "properties": {
        "entity_id": { "type": "string" },
        "entity_type": {
          "type": "string",
          "enum": ["point", "line", "circle", "arc", "rectangle", "slot", "polygon", "construction_line"]
        },
        "parameters": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/parameter_value" }
        }
      },
      "required": ["entity_id", "entity_type"]
    },
    "constraint": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "唯一識別碼" },
        "type": {
          "type": "string",
          "enum": [
            "horizontal",
            "vertical",
            "parallel",
            "perpendicular",
            "concentric",
            "tangent",
            "coincident",
            "equal",
            "equal_length",
            "distance",
            "radius",
            "diameter",
            "midpoint",
            "angle",
            "symmetric"
          ]
        },
        "targets": {
          "type": "array",
          "items": { "type": "string" },
          "description": "受約束的草圖實體 ID"
        },
        "value_mm": { "type": "number", "description": "距離/半徑/直徑值（mm）" },
        "value_deg": { "type": "number", "description": "角度值（度）" },
        "name": { "type": "string", "description": "方程式參照名稱，如 d1, R5" },
        "value": { "$ref": "#/definitions/parameter_value" },
        "metadata": {
          "type": "object",
          "description": "宣告式中繼資料",
          "properties": {
            "verified": { "type": "boolean" }
          }
        }
      },
      "required": ["id", "type", "targets"]
    },
    "feature": {
      "type": "object",
      "required": ["feature_id", "type", "name"],
      "properties": {
        "feature_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "唯一且穩定的特徵識別碼"
        },
        "type": {
          "type": "string",
          "enum": [
            "sketch",
            "pad",
            "pocket",
            "revolve",
            "sweep",
            "loft",
            "hole",
            "linear_pattern",
            "circular_pattern",
            "mirror",
            "fillet",
            "chamfer",
            "shell",
            "boolean_union",
            "boolean_difference",
            "boolean_intersection",
            "draft",
            "rib",
            "thin",
            "variable_fillet",
            "countersink",
            "cosmetic_thread"
          ]
        },
        "name": {
          "type": "string",
          "description": "人類可讀特徵名稱"
        },
        "input": {
          "type": "string",
          "description": "輸入參照特徵 ID（如草圖或實體）"
        },
        "references": {
          "type": "array",
          "items": { "type": "string" },
          "description": "依賴特徵 ID 列表"
        },
        "sketch_entities": {
          "type": "array",
          "items": { "$ref": "#/definitions/sketch_entity" },
          "description": "草圖實體（sketch 類型使用）"
        },
        "constraints": {
          "type": "array",
          "items": { "$ref": "#/definitions/constraint" },
          "description": "草圖約束（宣告式中繼資料）"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/parameter_value" },
          "description": "特徵參數"
        },
        "standard_parts": {
          "type": "object",
          "description": "標準件參考（如 M5 間隙孔，由引擎查表）"
        },
        "plane": {
          "type": "object",
          "description": "草圖基準面（sketch 類型使用）。預設 XY=上基準面。",
          "properties": {
            "base": {
              "type": "string",
              "oneOf": [
                { "enum": ["XY", "XZ", "YZ"] },
                { "pattern": "^datum:.+" }
              ],
              "description": "XY=上(Top)、XZ=前(Front)、YZ=右(Right)，或 datum:<id> 引用基準面（WP-S1：與 Python/C# validator 對齊）"
            },
            "offset": {
              "$ref": "#/definitions/parameter_value",
              "description": "沿法向偏移量(mm)，預設 0"
            }
          },
          "required": ["base"]
        },
        "validation": {
          "type": "object",
          "description": "驗證條件",
          "properties": {
            "min_thickness_mm": { "type": "number" },
            "must_be_single_solid": { "type": "boolean" },
            "expected_hole_count": { "type": "integer" },
            "expected_bounding_box": {
              "type": "object",
              "properties": {
                "min": {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 3
                },
                "max": {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 3
                }
              }
            }
          }
        },
        "source": {
          "type": "string",
          "enum": ["llm", "user", "imported"],
          "description": "建立來源"
        },
        "llm_description": {
          "type": "string",
          "description": "LLM 設計說明"
        },
        "rebuild_status": {
          "type": "string",
          "enum": ["pending", "building", "success", "failed"],
          "description": "重建狀態"
        },
        "error_message": {
          "type": "string",
          "description": "錯誤訊息（重建失敗時）"
        }
      }
    },
    "reference_geometry": {
      "type": "object",
      "description": "WP1-3 基準幾何——datum plane/axis/point",
      "properties": {
        "id": { "type": "string", "description": "唯一識別碼" },
        "name": { "type": "string", "description": "顯示名稱" },
        "kind": { "type": "string", "enum": ["plane", "axis", "point"], "description": "基準類型" },
        "definition": {
          "type": "object",
          "description": "定義方式",
          "properties": {
            "method": {
              "type": "string",
              "enum": ["offset", "angle_between", "mid_plane", "intersection", "cylinder_axis", "vertex", "center"],
              "description": "建立方法"
            },
            "source_ref": { "type": "string", "description": "來源面/邊的語意參照" },
            "source_ref_2": { "type": "string", "description": "第二來源" },
            "offset_mm": { "type": "number", "description": "偏移量（mm）" },
            "angle_deg": { "type": "number", "description": "夾角（度）" }
          },
          "required": ["method"]
        },
        "derived_geometry": {
          "type": "object",
          "description": "重建後計算出的幾何座標（worker 填入）",
          "properties": {
            "origin": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
            "normal": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
            "direction": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3, "description": "軸方向（axis）" },
            "point": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3, "description": "點座標（point）" }
          }
        }
      },
      "required": ["id", "kind", "definition"]
    }
  }
}
