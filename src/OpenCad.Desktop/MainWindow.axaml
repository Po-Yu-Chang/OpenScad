<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenCad.Desktop.ViewModels"
        x:Class="OpenCad.Desktop.MainWindow"
        Title="OpenCad — 全本地 LLM 原生參數化機械 CAD"
        Width="1280" Height="800"
        MinWidth="960" MinHeight="600"
        Background="{DynamicResource BaseBrush}">

    <!-- 鍵盤快捷鍵 -->
    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}" />
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}" />
    </Window.KeyBindings>

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <!-- 根佈局：工具列 + 主體 + 狀態列 -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ═══ 工具列 ═══ -->
        <Border Grid.Row="0" Background="{DynamicResource MantleBrush}" Padding="8,4">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto,Auto,Auto,Auto,Auto">
                <!-- 檔案選單 -->
                <Menu Grid.Column="0" Background="Transparent">
                    <MenuItem Header="檔案" Foreground="{DynamicResource TextBrush}">
                        <MenuItem Header="開啟專案" Command="{Binding OpenProjectCommand}" ToolTip.Tip="列出已存專案" />
                        <MenuItem Header="儲存專案" Command="{Binding SaveProjectCommand}" IsEnabled="False" ToolTip.Tip="Phase 1 實作" />
                        <Separator />
                        <MenuItem Header="LLM 設定…" Command="{Binding OpenLlmSettingsCommand}" ToolTip.Tip="設定 OpenAI-compatible 端點（LiteLLM／Ollama）" />
                        <MenuItem Header="重新偵測 LLM" Command="{Binding RedetectLlmCommand}" ToolTip.Tip="修改設定檔後重新連線" />
                    </MenuItem>
                </Menu>

                <!-- 載入範例 -->
                <Menu Grid.Column="1" Background="Transparent" Margin="8,0,0,0">
                    <MenuItem Header="載入範例▾" Foreground="{DynamicResource TextBrush}">
                        <MenuItem Header="NEMA17 馬達座" Command="{Binding LoadExampleCommand}" CommandParameter="nema17-mount" />
                        <MenuItem Header="針盒收納盒 5×10" Command="{Binding LoadExampleCommand}" CommandParameter="needle-box-5x10" />
                        <MenuItem Header="ESP32-CAM 外殼" Command="{Binding LoadExampleCommand}" CommandParameter="esp32cam-enclosure" />
                    </MenuItem>
                </Menu>

                <!-- 新增專案 -->
                <Button Grid.Column="2" Classes="tool" Content="新增專案" Command="{Binding NewProjectCommand}" Margin="8,0,0,0" />

                <!-- 新增草圖 -->
                <Button Grid.Column="3" Classes="tool" Content="✏ 草圖" Command="{Binding NewSketchCommand}" Margin="4,0,0,0" ToolTip.Tip="建立新草圖並進入編輯" />

                <!-- 重建 -->
                <Button Grid.Column="4" Classes="primary" Content="重建" Command="{Binding RebuildCommand}" Margin="8,0,0,0" />

                <!-- 復原/重做 -->
                <Button Grid.Column="5" Classes="tool" Content="↶ 復原" Command="{Binding UndoCommand}" Margin="8,0,0,0" ToolTip.Tip="Ctrl+Z" />
                <Button Grid.Column="6" Classes="tool" Content="↷ 重做" Command="{Binding RedoCommand}" Margin="4,0,0,0" ToolTip.Tip="Ctrl+Y" />

                <!-- 右側動作 -->
                <Button Grid.Column="8" Classes="tool" Content="匯出 STEP" Command="{Binding ExportCommand}" CommandParameter="step" Margin="0,0,8,0" />
                <Button Grid.Column="9" Classes="tool" Content="匯出 STL" Command="{Binding ExportCommand}" CommandParameter="stl" Margin="0,0,8,0" />

                <!-- 匯出對話紀錄（供分析 LLM 意圖判斷） -->
                <Button Grid.Column="10" Classes="tool" Content="💬 匯出對話" Command="{Binding ExportChatCommand}" Margin="0,0,8,0" ToolTip.Tip="將聊天紀錄匯出為 Markdown，方便分析 LLM 意圖判斷效果" />

                <!-- 收合右欄 -->
                <Button Grid.Column="11" Classes="tool" Content="⚙" Command="{Binding ToggleRightPanelCommand}" ToolTip.Tip="開啟／收合對話窗格（輸入框在此欄）" />
            </Grid>
        </Border>

        <!-- ═══ 主體三欄 ═══ -->
        <Grid Grid.Row="1" ColumnDefinitions="260,4,*,4,300">

            <!-- 左欄：特徵樹 + 參數面板 -->
            <Grid Grid.Column="0" RowDefinitions="*,4,*" Background="{DynamicResource MantleBrush}">
                <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Text="特徵樹" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="12,8,0,4" />
                        <TreeView Grid.Row="1" ItemsSource="{Binding FeatureTree}"
                                  SelectedItem="{Binding SelectedFeature}"
                                  Margin="8,0,8,8"
                                  Background="Transparent">
                            <TreeView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="✏ 新增草圖" Command="{Binding NewSketchCommand}" />
                                    <MenuItem Header="✏ 編輯草圖" Command="{Binding EditSketchCommand}" IsVisible="{Binding CanEditSketch}" />
                                    <MenuItem Header="📝 編輯參數" Command="{Binding EditParametersCommand}" />
                                    <MenuItem Header="🗑 刪除" Command="{Binding DeleteFeatureCommand}" />
                                </ContextMenu>
                            </TreeView.ContextMenu>
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{Binding TypeIcon}" Foreground="{DynamicResource AccentBrush}" FontSize="14" />
                                        <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource TextBrush}" />
                                    </StackPanel>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="1" Background="{DynamicResource BorderBrush}" ResizeDirection="Rows" />

                <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <TextBlock Grid.Row="0" Text="參數面板" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="12,8,0,4" />
                        <Button Grid.Row="1" Classes="tool" Content="✏ 編輯草圖" Command="{Binding EditSketchCommand}"
                                Margin="12,0,12,4" IsVisible="{Binding CanEditSketch}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                        <ScrollViewer Grid.Row="2" Padding="8">
                            <ItemsControl ItemsSource="{Binding SelectedFeatureParameters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="100,*,Auto" Margin="0,2">
                                            <TextBlock Grid.Column="0" Text="{Binding Key}" Foreground="{DynamicResource SubtextBrush}" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1" Text="{Binding Value}" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas" FontSize="11"
                                                     IsReadOnly="{Binding !IsEditable}" Background="Transparent" BorderThickness="0,0,0,1"
                                                     Padding="2" Margin="0,0,0,2" />
                                            <Button Grid.Column="2" Content="✓" FontSize="11" Padding="6,2" Margin="4,0,0,0"
                                                    Command="{Binding ApplyCommand}" IsVisible="{Binding IsDirty}"
                                                    Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource CrustBrush}"
                                                    ToolTip.Tip="套用此參數並重建" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" Background="{DynamicResource BorderBrush}" ResizeDirection="Columns" Width="4" />

            <!-- 中欄：3D Viewport（主角）-->
            <Grid Grid.Column="2" Background="{DynamicResource BaseBrush}">

                <!-- WebView -->
                <WebView x:Name="PART_Viewer" />

            </Grid>

            <!-- 右欄：對話歷史（可收合） -->
            <GridSplitter Grid.Column="3" Background="{DynamicResource BorderBrush}" ResizeDirection="Columns" Width="4"
                          IsVisible="{Binding IsRightPanelVisible}" />

            <Border Grid.Column="4" Background="{DynamicResource MantleBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                    IsVisible="{Binding IsRightPanelVisible}">
                <Grid RowDefinitions="*,Auto,Auto">
                    <!-- 對話歷史 -->
                    <ScrollViewer Grid.Row="0" Padding="8" x:Name="PART_ChatScroll">
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="4">
                                        <!-- User 訊息 -->
                                        <Border Classes="msg-user" IsVisible="{Binding Kind, Converter={x:Static vm:MessageKindToVisibilityConverter.UserIsVisible}}">
                                            <TextBlock Text="{Binding Text}" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" />
                                        </Border>

                                        <!-- Assistant 訊息 -->
                                        <Border Classes="msg-assistant" IsVisible="{Binding Kind, Converter={x:Static vm:MessageKindToVisibilityConverter.AssistantIsVisible}}">
                                            <TextBlock Text="{Binding Text}" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" />
                                        </Border>

                                        <!-- Error 訊息 -->
                                        <Border Classes="msg-error" IsVisible="{Binding Kind, Converter={x:Static vm:MessageKindToVisibilityConverter.ErrorIsVisible}}">
                                            <TextBlock Text="{Binding Text}" Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap" />
                                        </Border>

                                        <!-- Plan 計畫卡片 -->
                                        <Border Classes="msg-plan" IsVisible="{Binding Kind, Converter={x:Static vm:MessageKindToVisibilityConverter.PlanIsVisible}}">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="建模計畫" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" />
                                                <TextBlock Text="{Binding Text}" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" />
                                                <!-- 步驟清單 -->
                                                <ItemsControl ItemsSource="{Binding Plan.Steps}" Margin="0,4,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Foreground="{DynamicResource SubtextBrush}" FontSize="12" TextWrapping="Wrap">
                                                                <Run Text="" />
                                                                <Run Text="{Binding Description}" />
                                                            </TextBlock>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <!-- 缺少資訊 -->
                                                <ItemsControl ItemsSource="{Binding Plan.MissingInfo}" IsVisible="{Binding Plan.MissingInfo.Count}" Margin="0,4,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Foreground="{DynamicResource WarningBrush}" FontSize="11" TextWrapping="Wrap"
                                                                       Text="{Binding}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <!-- 按鈕列 -->
                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                                                    <Button Classes="primary" Content="套用" Command="{Binding ApplyPlanCommand}" IsEnabled="{Binding IsActionable}" />
                                                    <Button Classes="tool" Content="取消" Command="{Binding CancelPlanCommand}" IsEnabled="{Binding IsActionable}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Diff 修改差異卡片 -->
                                        <Border Classes="msg-plan" IsVisible="{Binding Kind, Converter={x:Static vm:MessageKindToVisibilityConverter.DiffIsVisible}}">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="修改差異" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" />
                                                <TextBlock Text="{Binding Text}" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" FontSize="12" />
                                                <!-- 特徵 ID -->
                                                <TextBlock Foreground="{DynamicResource SubtextBrush}" FontSize="11"
                                                           Text="{Binding Diff.FeatureId, StringFormat='目標特徵：{0}'}" />
                                                <!-- Before/After 參數對照 -->
                                                <Border Background="{DynamicResource MantleBrush}" CornerRadius="4" Padding="8" Margin="0,4,0,0">
                                                    <Grid ColumnDefinitions="1*,1*">
                                                        <StackPanel Grid.Column="0" Spacing="2">
                                                            <TextBlock Text="修改前" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource SubtextBrush}" />
                                                            <ItemsControl ItemsSource="{Binding Diff.Before}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"><Run Text="{Binding Key}" FontWeight="Bold" /><Run Text=": " /><Run Text="{Binding Value}" /></TextBlock>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Spacing="2">
                                                            <TextBlock Text="修改後" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource AccentBrush}" />
                                                            <ItemsControl ItemsSource="{Binding Diff.After}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"><Run Text="{Binding Key}" FontWeight="Bold" /><Run Text=": " /><Run Text="{Binding Value}" /></TextBlock>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <!-- 按鈕列 -->
                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                                                    <Button Classes="primary" Content="套用修改" Command="{Binding ApplyDiffCommand}" IsEnabled="{Binding IsActionable}" />
                                                    <Button Classes="tool" Content="取消" Command="{Binding CancelDiffCommand}" IsEnabled="{Binding IsActionable}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- LLM 狀態 -->
                    <TextBlock Grid.Row="1" Text="{Binding LlmStatus}" Foreground="{DynamicResource SubtextBrush}"
                               FontSize="11" Margin="8,4,8,4" />

                    <!-- 輸入框（底部） -->
                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="8,0,8,8">
                        <TextBox x:Name="PART_PromptInput" Grid.Column="0" Text="{Binding InputText}" Watermark="描述設計需求…"
                                 Background="{DynamicResource BaseBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 AcceptsReturn="True" MinHeight="36" MaxHeight="100"
                                 CaretBrush="{DynamicResource AccentBrush}"
                                 TextWrapping="Wrap" Padding="6" />
                        <Button Grid.Column="1" Classes="primary" Content="送出"
                                Command="{Binding SendCommand}" VerticalAlignment="Center" Margin="4,0,0,0" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ 狀態列 ═══ -->
        <Border Grid.Row="2" Background="{DynamicResource CrustBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,4">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="{Binding WorkerStatus}" FontFamily="Consolas" FontSize="11"
                           Foreground="{DynamicResource SuccessBrush}"
                           IsVisible="{Binding IsWorkerConnected}" />
                <TextBlock Text="{Binding WorkerStatus}" FontFamily="Consolas" FontSize="11"
                           Foreground="{DynamicResource ErrorBrush}"
                           IsVisible="{Binding !IsWorkerConnected}" />
                <TextBlock Foreground="{DynamicResource SubtextBrush}" Text="{Binding LlmStatus}" FontFamily="Consolas" FontSize="11" />
                <TextBlock Foreground="{DynamicResource SubtextBrush}" Text="{Binding ModelInfoText}" FontFamily="Consolas" FontSize="11" />
                <TextBlock Foreground="{DynamicResource SubtextBrush}" Text="{Binding MassInfoText}" FontFamily="Consolas" FontSize="11"
                           IsVisible="{Binding MassInfoText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <TextBlock Text="⏳ 重建中…" Foreground="{DynamicResource WarningBrush}" FontFamily="Consolas" FontSize="11"
                           IsVisible="{Binding IsBusy}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>