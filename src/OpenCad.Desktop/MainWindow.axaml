<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenCad.Desktop.ViewModels"
        x:Class="OpenCad.Desktop.MainWindow"
        Title="OpenCad — 全本地 LLM 原生參數化機械 CAD"
        Width="1280" Height="800"
        MinWidth="960" MinHeight="600"
        Background="{DynamicResource BaseBrush}">

    <!-- 鍵盤快捷鍵 -->
    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}" />
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}" />
    </Window.KeyBindings>

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <!-- 根佈局：工具列 + 主體 + 狀態列 -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ═══ 工具列 ═══ 左群組（可橫向捲動，不再疊欄）＋ 右群組（固定靠右） -->
        <Border Grid.Row="0" Background="{DynamicResource MantleBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,5">
            <Grid ColumnDefinitions="*,Auto,Auto">

                <!-- 左群組 -->
                <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <!-- 專案切換器：顯示目前專案，下拉可回首頁／新專案／設定 -->
                        <Menu Background="Transparent">
                            <MenuItem Foreground="{DynamicResource TextBrush}" ToolTip.Tip="專案切換">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                        <TextBlock Text="✛" Foreground="{DynamicResource AccentBrush}" FontSize="14" />
                                        <TextBlock Text="{Binding CurrentProjectName}" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" />
                                        <TextBlock Text="▾" Foreground="{DynamicResource SubtextBrush}" FontSize="11" />
                                    </StackPanel>
                                </MenuItem.Header>
                                <MenuItem Header="🏠 開啟／首頁" Command="{Binding ShowStartPageCommand}" ToolTip.Tip="顯示專案縮圖首頁" />
                                <MenuItem Header="＋ 新專案" Command="{Binding NewProjectCommand}" />
                                <MenuItem Header="↻ 重新整理清單" Command="{Binding RefreshProjectListCommand}" />
                                <Separator />
                                <MenuItem Header="LLM 設定…" Command="{Binding OpenLlmSettingsCommand}" ToolTip.Tip="設定 OpenAI-compatible 端點（LiteLLM／Ollama）" />
                                <MenuItem Header="重新偵測 LLM" Command="{Binding RedetectLlmCommand}" ToolTip.Tip="修改設定檔後重新連線" />
                            </MenuItem>
                        </Menu>

                        <Border Width="1" Margin="6,5" Background="{DynamicResource BorderBrush}" />

                        <!-- 建立類 -->
                        <Button Classes="tool" Content="✏ 草圖" Command="{Binding NewSketchCommand}" ToolTip.Tip="建立新草圖並進入編輯" />
                        <Button Classes="tool" Content="📐 基準面" Command="{Binding CreateDatumPlaneCommand}" ToolTip.Tip="建立偏移基準面" />

                        <Border Width="1" Margin="6,5" Background="{DynamicResource BorderBrush}" />

                        <!-- 工具：量測／選取過濾／顯示模式 併入單一選單 -->
                        <Menu Background="Transparent">
                            <MenuItem Header="🔧 工具" Foreground="{DynamicResource TextBrush}" ToolTip.Tip="量測／選取過濾／顯示模式">
                                <MenuItem Header="📏 量測模式" Command="{Binding ToggleMeasureCommand}" ToolTip.Tip="點兩個面/邊/點顯示距離/角度/半徑" />
                                <Separator />
                                <MenuItem Header="🩹 選取過濾">
                                    <MenuItem Header="全部" Command="{Binding SetSelectionFilterCommand}" CommandParameter="{x:Static vm:SelectionFilter.All}" />
                                    <MenuItem Header="面" Command="{Binding SetSelectionFilterCommand}" CommandParameter="{x:Static vm:SelectionFilter.Face}" />
                                    <MenuItem Header="邊" Command="{Binding SetSelectionFilterCommand}" CommandParameter="{x:Static vm:SelectionFilter.Edge}" />
                                    <MenuItem Header="頂點" Command="{Binding SetSelectionFilterCommand}" CommandParameter="{x:Static vm:SelectionFilter.Vertex}" />
                                </MenuItem>
                                <MenuItem Header="👁 顯示模式">
                                    <MenuItem Header="實體著色" Command="{Binding SetDisplayModeCommand}" CommandParameter="{x:Static vm:DisplayMode.Shaded}" />
                                    <MenuItem Header="著色+邊線" Command="{Binding SetDisplayModeCommand}" CommandParameter="{x:Static vm:DisplayMode.ShadedWithEdges}" />
                                    <MenuItem Header="線框" Command="{Binding SetDisplayModeCommand}" CommandParameter="{x:Static vm:DisplayMode.Wireframe}" />
                                    <MenuItem Header="透明" Command="{Binding SetDisplayModeCommand}" CommandParameter="{x:Static vm:DisplayMode.Transparent}" />
                                </MenuItem>
                            </MenuItem>
                        </Menu>

                    </StackPanel>
                </ScrollViewer>

                <!-- 固定群組：重建/復原/重做——常駐可見，不隨左群組捲動 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <Border Width="1" Margin="6,5" Background="{DynamicResource BorderBrush}" />
                    <Button Classes="primary" Content="重建" Command="{Binding RebuildCommand}" Margin="2,0" />
                    <Button Classes="tool" Content="↶ 復原" Command="{Binding UndoCommand}" ToolTip.Tip="Ctrl+Z" />
                    <Button Classes="tool" Content="↷ 重做" Command="{Binding RedoCommand}" ToolTip.Tip="Ctrl+Y" />
                </StackPanel>

                <!-- 右群組：固定靠右 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Menu Background="Transparent">
                        <MenuItem Header="⬇ 匯出" Foreground="{DynamicResource TextBrush}" ToolTip.Tip="匯出模型或對話">
                            <MenuItem Header="STEP（實體）" Command="{Binding ExportCommand}" CommandParameter="step" />
                            <MenuItem Header="STL（網格）" Command="{Binding ExportCommand}" CommandParameter="stl" />
                            <Separator />
                            <MenuItem Header="💬 對話紀錄（Markdown）" Command="{Binding ExportChatCommand}" ToolTip.Tip="將聊天紀錄匯出為 Markdown，方便分析 LLM 意圖判斷效果" />
                        </MenuItem>
                    </Menu>
                    <Button Classes="tool" Content="⚙" Command="{Binding ToggleRightPanelCommand}" ToolTip.Tip="開啟／收合對話窗格（輸入框在此欄）" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ 主體三欄 ═══ -->
        <Grid Grid.Row="1" ColumnDefinitions="260,4,*,4,300">

            <!-- 左欄：特徵樹 + 參數面板 -->
            <Grid Grid.Column="0" RowDefinitions="*,4,*" Background="{DynamicResource MantleBrush}">
                <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Classes="h" Text="特徵樹" Margin="12,8,0,4" />
                        <TreeView Grid.Row="1" ItemsSource="{Binding FeatureTree}"
                                  SelectedItem="{Binding SelectedFeature}"
                                  Margin="8,0,8,8"
                                  Background="Transparent">
                            <TreeView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="✏ 新增草圖" Command="{Binding NewSketchCommand}" />
                                    <MenuItem Header="✏ 編輯草圖" Command="{Binding EditSketchCommand}" IsVisible="{Binding CanEditSketch}" />
                                    <MenuItem Header="📝 編輯參數" Command="{Binding EditParametersCommand}" />
                                    <MenuItem Header="🗑 刪除" Command="{Binding DeleteFeatureCommand}" />
                                    <Separator />
                                    <MenuItem Header="⊘ 抑制" Command="{Binding SuppressFeatureCommand}" />
                                    <MenuItem Header="⊙ 取消抑制" Command="{Binding UnsuppressFeatureCommand}" />
                                    <Separator />
                                            <MenuItem Header="🔍 隔離" Command="{Binding IsolateFeatureCommand}" />
                                            <MenuItem Header="🙈 隱藏" Command="{Binding HideFeatureCommand}" />
                                            <MenuItem Header="👁 顯示全部" Command="{Binding ShowAllFeaturesCommand}" />
                                            <Separator />
                                            <MenuItem Header="⏮ 回溯到此" Command="{Binding RollbackToHereCommand}" />
                                            <MenuItem Header="⏭ 回到末端" Command="{Binding RollbackToEndCommand}" />
                                        </ContextMenu>
                                    </TreeView.ContextMenu>
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{Binding TypeIcon}" Foreground="{DynamicResource AccentBrush}" FontSize="14" />
                                        <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource TextBrush}" />
                                        <TextBlock Text="{Binding StateIcon}" Foreground="{Binding StateColor}" FontSize="14" />
                                    </StackPanel>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="1" Background="{DynamicResource BorderBrush}" ResizeDirection="Rows" />

                <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Grid RowDefinitions="Auto,Auto,Auto,*">
                        <TextBlock Grid.Row="0" Classes="h" Text="參數面板" Margin="12,8,0,4" />
                        <Button Grid.Row="1" Classes="tool" Content="✏ 編輯草圖" Command="{Binding EditSketchCommand}"
                                Margin="12,0,12,4" IsVisible="{Binding CanEditSketch}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                        <Button Grid.Row="2" Classes="primary" Content="✓ 全部套用" Command="{Binding ApplyAllParametersCommand}"
                                Margin="12,0,12,4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                ToolTip.Tip="套用所有已修改的參數並重建" />
                        <ScrollViewer Grid.Row="3" Padding="8">
                            <ItemsControl ItemsSource="{Binding SelectedFeatureParameters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="100,*,Auto" Margin="0,2">
                                            <TextBlock Grid.Column="0" Text="{Binding Key}" Foreground="{DynamicResource SubtextBrush}" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" />
                                            <!-- Number type: TextBox -->
                                            <TextBox Grid.Column="1" Text="{Binding Value}" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas" FontSize="11"
                                                     IsReadOnly="{Binding !IsEditable}" Background="Transparent" BorderThickness="0,0,0,1"
                                                     Padding="2" Margin="0,0,0,2"
                                                     IsVisible="{Binding ParamType, Converter={x:Static vm:EnumEqualsConverter.IsNumber}}" />
                                            <!-- Dropdown type: ComboBox -->
                                            <ComboBox Grid.Column="1" ItemsSource="{Binding DropdownOptions}" SelectedItem="{Binding Value}"
                                                      FontFamily="Consolas" FontSize="11" Margin="0,0,0,2"
                                                      IsVisible="{Binding ParamType, Converter={x:Static vm:EnumEqualsConverter.IsDropdown}}" />
                                            <!-- Checkbox type: CheckBox -->
                                            <CheckBox Grid.Column="1" IsChecked="{Binding Value, Converter={x:Static vm:StringToBoolConverter.Instance}}"
                                                      Content="{Binding Value}" FontFamily="Consolas" FontSize="11" Margin="0,0,0,2"
                                                      IsVisible="{Binding ParamType, Converter={x:Static vm:EnumEqualsConverter.IsCheckbox}}" />
                                            <!-- Reference type: Button to pick in viewer -->
                                            <Button Grid.Column="1" Content="{Binding ReferenceHint}" FontFamily="Consolas" FontSize="11"
                                                    Padding="2" Margin="0,0,0,2" HorizontalAlignment="Stretch"
                                                    Background="Transparent" BorderThickness="0,0,0,1"
                                                    IsVisible="{Binding ParamType, Converter={x:Static vm:EnumEqualsConverter.IsReference}}" />
                                            <!-- ReadOnly type: TextBlock -->
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="{DynamicResource SubtextBrush}"
                                                       FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"
                                                       Margin="0,0,0,2" Padding="2"
                                                       IsVisible="{Binding ParamType, Converter={x:Static vm:EnumEqualsConverter.IsReadOnly}}" />
                                            <Button Grid.Column="2" Content="✓" FontSize="11" Padding="6,2" Margin="4,0,0,0"
                                                    Command="{Binding ApplyCommand}" IsVisible="{Binding IsDirty}"
                                                    Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource CrustBrush}"
                                                    ToolTip.Tip="套用此參數並重建" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" Background="{DynamicResource BorderBrush}" ResizeDirection="Columns" Width="4" />

            <!-- 中欄：3D Viewport（主角）-->
            <Grid Grid.Column="2" Background="{DynamicResource BaseBrush}">

                <!-- WebView -->
                <WebView x:Name="PART_Viewer" />

            </Grid>

            <!-- 右欄：對話歷史（可收合） -->
            <GridSplitter Grid.Column="3" Background="{DynamicResource BorderBrush}" ResizeDirection="Columns" Width="4"
                          IsVisible="{Binding IsRightPanelVisible}" />

            <Border Grid.Column="4" Background="{DynamicResource MantleBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                    IsVisible="{Binding IsRightPanelVisible}">
                <Grid RowDefinitions="*,Auto,Auto">
                    <!-- 對話歷史 -->
                    <ScrollViewer Grid.Row="0" Padding="8" x:Name="PART_ChatScroll">
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="4">
                                        <!-- User 訊息 -->
                                        <Border Classes="msg-user" IsVisible="{Binding Kind, Converter={x:Static vm:MessageKindToVisibilityConverter.UserIsVisible}}">
                                            <TextBlock Text="{Binding Text}" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" />
                                        </Border>

                                        <!-- Assistant 訊息 -->
                                        <Border Classes="msg-assistant" IsVisible="{Binding Kind, Converter={x:Static vm:MessageKindToVisibilityConverter.AssistantIsVisible}}">
                                            <TextBlock Text="{Binding Text}" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" />
                                        </Border>

                                        <!-- Error 訊息 -->
                                        <Border Classes="msg-error" IsVisible="{Binding Kind, Converter={x:Static vm:MessageKindToVisibilityConverter.ErrorIsVisible}}">
                                            <TextBlock Text="{Binding Text}" Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap" />
                                        </Border>

                                        <!-- Plan 計畫卡片 -->
                                        <Border Classes="msg-plan" IsVisible="{Binding Kind, Converter={x:Static vm:MessageKindToVisibilityConverter.PlanIsVisible}}">
                                            <StackPanel Spacing="6">
                                                <TextBlock Classes="h" Text="建模計畫" Foreground="{DynamicResource AccentBrush}" />
                                                <TextBlock Text="{Binding Text}" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" />
                                                <!-- 步驟清單 -->
                                                <ItemsControl ItemsSource="{Binding Plan.Steps}" Margin="0,4,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Foreground="{DynamicResource SubtextBrush}" FontSize="12" TextWrapping="Wrap">
                                                                <Run Text="" />
                                                                <Run Text="{Binding Description}" />
                                                            </TextBlock>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <!-- 缺少資訊 -->
                                                <ItemsControl ItemsSource="{Binding Plan.MissingInfo}" IsVisible="{Binding Plan.MissingInfo.Count}" Margin="0,4,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Foreground="{DynamicResource WarningBrush}" FontSize="11" TextWrapping="Wrap"
                                                                       Text="{Binding}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <!-- 按鈕列 -->
                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                                                    <Button Classes="primary" Content="套用" Command="{Binding ApplyPlanCommand}" IsEnabled="{Binding IsActionable}" />
                                                    <Button Classes="tool" Content="取消" Command="{Binding CancelPlanCommand}" IsEnabled="{Binding IsActionable}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Diff 修改差異卡片 -->
                                        <Border Classes="msg-plan" IsVisible="{Binding Kind, Converter={x:Static vm:MessageKindToVisibilityConverter.DiffIsVisible}}">
                                            <StackPanel Spacing="6">
                                                <TextBlock Classes="h" Text="修改差異" Foreground="{DynamicResource AccentBrush}" />
                                                <TextBlock Text="{Binding Text}" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" FontSize="12" />
                                                <!-- 特徵 ID -->
                                                <TextBlock Foreground="{DynamicResource SubtextBrush}" FontSize="11"
                                                           Text="{Binding Diff.FeatureId, StringFormat='目標特徵：{0}'}" />
                                                <!-- Before/After 參數對照 -->
                                                <Border Background="{DynamicResource MantleBrush}" CornerRadius="4" Padding="8" Margin="0,4,0,0">
                                                    <Grid ColumnDefinitions="1*,1*">
                                                        <StackPanel Grid.Column="0" Spacing="2">
                                                            <TextBlock Text="修改前" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource SubtextBrush}" />
                                                            <ItemsControl ItemsSource="{Binding Diff.Before}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"><Run Text="{Binding Key}" FontWeight="Bold" /><Run Text=": " /><Run Text="{Binding Value}" /></TextBlock>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Spacing="2">
                                                            <TextBlock Text="修改後" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource AccentBrush}" />
                                                            <ItemsControl ItemsSource="{Binding Diff.After}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"><Run Text="{Binding Key}" FontWeight="Bold" /><Run Text=": " /><Run Text="{Binding Value}" /></TextBlock>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <!-- 按鈕列 -->
                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                                                    <Button Classes="primary" Content="套用修改" Command="{Binding ApplyDiffCommand}" IsEnabled="{Binding IsActionable}" />
                                                    <Button Classes="tool" Content="取消" Command="{Binding CancelDiffCommand}" IsEnabled="{Binding IsActionable}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- LLM 狀態 -->
                    <TextBlock Grid.Row="1" Text="{Binding LlmStatus}" Foreground="{DynamicResource SubtextBrush}"
                               FontSize="11" Margin="8,4,8,4" />

                    <!-- 輸入框（底部） -->
                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="8,0,8,8">
                        <TextBox x:Name="PART_PromptInput" Grid.Column="0" Text="{Binding InputText}" Watermark="描述設計需求…"
                                 Background="{DynamicResource BaseBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 AcceptsReturn="True" MinHeight="36" MaxHeight="100"
                                 CaretBrush="{DynamicResource AccentBrush}"
                                 TextWrapping="Wrap" Padding="6" />
                        <Button Grid.Column="1" Classes="primary" Content="送出"
                                Command="{Binding SendCommand}" VerticalAlignment="Center" Margin="4,0,0,0" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ 啟動首頁：覆蓋主體，無專案或按「首頁」時顯示 ═══ -->
        <Border Grid.Row="1" Background="{DynamicResource BaseBrush}" IsVisible="{Binding IsStartPageVisible}">
            <Grid RowDefinitions="Auto,Auto,*" MaxWidth="1040" Margin="36,24,36,12">

                <!-- 標題 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="4,8,0,4">
                    <TextBlock Text="✛" FontSize="32" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="OpenCad" Classes="h" FontSize="26" />
                        <TextBlock Text="全本地 LLM 原生參數化機械 CAD" Foreground="{DynamicResource SubtextBrush}" FontSize="12" />
                    </StackPanel>
                </StackPanel>

                <!-- 動作列 -->
                <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*,Auto" Margin="4,18,4,10">
                    <Button Grid.Column="0" Classes="primary" Content="＋ 新專案" Command="{Binding NewProjectCommand}" Margin="0,0,8,0" />
                    <Menu Grid.Column="1" Background="Transparent" VerticalAlignment="Center">
                        <MenuItem Header="載入範例 ▾" Foreground="{DynamicResource TextBrush}">
                            <MenuItem Header="NEMA17 馬達座" Command="{Binding LoadExampleCommand}" CommandParameter="nema17-mount" />
                            <MenuItem Header="針盒收納盒 5×10" Command="{Binding LoadExampleCommand}" CommandParameter="needle-box-5x10" />
                            <MenuItem Header="ESP32-CAM 外殼" Command="{Binding LoadExampleCommand}" CommandParameter="esp32cam-enclosure" />
                        </MenuItem>
                    </Menu>
                    <Button Grid.Column="3" Classes="tool" Content="↻ 重新整理" Command="{Binding RefreshProjectListCommand}" />
                </Grid>

                <!-- 專案網格 -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="最近的專案" Classes="h" FontSize="14" Margin="6,4,0,8" />
                        <TextBlock Text="尚無專案——點「＋ 新專案」或「載入範例」開始。"
                                   Foreground="{DynamicResource SubtextBrush}" Margin="6,8" FontSize="13"
                                   IsVisible="{Binding RecentProjects.Count, Converter={x:Static vm:IntIsZeroConverter.Instance}}" />
                        <ItemsControl ItemsSource="{Binding RecentProjects}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="proj-card">
                                        <Grid>
                                            <!-- 一般狀態：縮圖＋資訊＋動作 -->
                                            <StackPanel IsVisible="{Binding IsNormal}">
                                                <Button Classes="card-open"
                                                        Command="{Binding $parent[ItemsControl].DataContext.OpenProjectFromSummaryCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="開啟此專案">
                                                    <StackPanel>
                                                        <!-- 縮圖區 -->
                                                        <Panel Height="128">
                                                            <Border Background="{DynamicResource CrustBrush}" CornerRadius="12,12,0,0" />
                                                            <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                                                   IsVisible="{Binding HasThumbnailImage}" />
                                                            <TextBlock Text="{Binding Initial}" FontSize="46" FontWeight="Bold"
                                                                       Foreground="{DynamicResource OverlayBrush}"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       IsVisible="{Binding !HasThumbnailImage}" />
                                                        </Panel>
                                                        <!-- 資訊 -->
                                                        <StackPanel Margin="12,8,12,4" Spacing="2">
                                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextBrush}"
                                                                       FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" />
                                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                                <TextBlock Text="{Binding FeatureCountText}" Foreground="{DynamicResource SubtextBrush}" FontSize="11" />
                                                                <TextBlock Text="{Binding ModifiedRelative}" Foreground="{DynamicResource SubtextBrush}" FontSize="11" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Button>
                                                <!-- 動作列 -->
                                                <StackPanel Orientation="Horizontal" Spacing="2" Margin="8,0,8,8" HorizontalAlignment="Right">
                                                    <Button Classes="card-act" Content="改名"
                                                            Command="{Binding $parent[ItemsControl].DataContext.BeginRenameCommand}" CommandParameter="{Binding}" />
                                                    <Button Classes="card-act" Content="複製"
                                                            Command="{Binding $parent[ItemsControl].DataContext.DuplicateProjectCommand}" CommandParameter="{Binding}" />
                                                    <Button Classes="card-act" Content="刪除"
                                                            Command="{Binding $parent[ItemsControl].DataContext.BeginDeleteCommand}" CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- 改名狀態 -->
                                            <StackPanel IsVisible="{Binding IsRenaming}" Margin="12" Spacing="8" MinHeight="180">
                                                <TextBlock Text="重新命名" Foreground="{DynamicResource SubtextBrush}" FontSize="11" />
                                                <TextBox Text="{Binding EditName}" Watermark="專案名稱"
                                                         Background="{DynamicResource BaseBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                                         Foreground="{DynamicResource TextBrush}" Padding="6" />
                                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                                    <Button Classes="primary" Content="確定"
                                                            Command="{Binding $parent[ItemsControl].DataContext.CommitRenameCommand}" CommandParameter="{Binding}" />
                                                    <Button Classes="tool" Content="取消"
                                                            Command="{Binding $parent[ItemsControl].DataContext.CancelCardActionCommand}" CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- 刪除確認狀態 -->
                                            <StackPanel IsVisible="{Binding IsConfirmingDelete}" Margin="12" Spacing="8" MinHeight="180" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name, StringFormat='確定刪除「{0}」？'}" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" />
                                                <TextBlock Text="此動作無法復原。" Foreground="{DynamicResource ErrorBrush}" FontSize="11" />
                                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                                    <Button Content="刪除" Foreground="{DynamicResource CreamTextBrush}" Background="{DynamicResource ErrorBrush}"
                                                            CornerRadius="8" Padding="14,6" FontWeight="SemiBold"
                                                            Command="{Binding $parent[ItemsControl].DataContext.ConfirmDeleteCommand}" CommandParameter="{Binding}" />
                                                    <Button Classes="tool" Content="取消"
                                                            Command="{Binding $parent[ItemsControl].DataContext.CancelCardActionCommand}" CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══ 後端未連線橫幅：解釋「為什麼工具列都按不動」，並提供重試 ═══ -->
        <Border Grid.Row="1" VerticalAlignment="Top" IsVisible="{Binding !IsWorkerConnected}"
                Background="{DynamicResource WarningBrush}" Padding="14,8">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="⚠" Foreground="{DynamicResource CreamTextBrush}"
                           FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock Grid.Column="1" Foreground="{DynamicResource CreamTextBrush}" VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Text="後端 CAD 引擎（Worker）未連線——建立/編輯/匯出等按鈕會暫時停用。請確認後端已啟動後重試。" />
                <Button Grid.Column="2" Content="↻ 重新連線" Command="{Binding ReconnectWorkerCommand}"
                        VerticalAlignment="Center" Margin="12,0,0,0"
                        Background="{DynamicResource CreamTextBrush}" Foreground="{DynamicResource TextBrush}"
                        CornerRadius="8" Padding="12,5" FontWeight="SemiBold" Cursor="Hand" />
            </Grid>
        </Border>

        <!-- ═══ 狀態列 ═══ -->
        <Border Grid.Row="2" Background="{DynamicResource CrustBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,4">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="{Binding WorkerStatus}" FontFamily="Consolas" FontSize="11"
                           Foreground="{DynamicResource SuccessBrush}"
                           IsVisible="{Binding IsWorkerConnected}" />
                <TextBlock Text="{Binding WorkerStatus}" FontFamily="Consolas" FontSize="11"
                           Foreground="{DynamicResource ErrorBrush}"
                           IsVisible="{Binding !IsWorkerConnected}" />
                <TextBlock Foreground="{DynamicResource SubtextBrush}" Text="{Binding LlmStatus}" FontFamily="Consolas" FontSize="11" />
                <TextBlock Foreground="{DynamicResource SubtextBrush}" Text="{Binding ModelInfoText}" FontFamily="Consolas" FontSize="11" />
                <TextBlock Foreground="{DynamicResource SubtextBrush}" Text="{Binding MassInfoText}" FontFamily="Consolas" FontSize="11"
                           IsVisible="{Binding MassInfoText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <TextBlock Text="⏳ 重建中…" Foreground="{DynamicResource WarningBrush}" FontFamily="Consolas" FontSize="11"
                           IsVisible="{Binding IsBusy}" />
                <!-- 自動儲存指示：取代原本誤導的停用「儲存專案」（後端本就有 revisions/journal 自動存檔） -->
                <TextBlock Text="✓ 已自動儲存" Foreground="{DynamicResource SuccessBrush}" FontFamily="Consolas" FontSize="11"
                           IsVisible="{Binding HasProject}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>