<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenCad.Desktop.ViewModels"
        x:Class="OpenCad.Desktop.MainWindow"
        Title="OpenCad — 全本地 LLM 原生參數化機械 CAD"
        Width="1280" Height="800"
        MinWidth="960" MinHeight="600"
        Background="{DynamicResource BaseBrush}">

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <!-- 根佈局：工具列 + 主體 + 狀態列 -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ═══ 工具列 ═══ -->
        <Border Grid.Row="0" Background="{DynamicResource MantleBrush}" Padding="8,4">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto,Auto,Auto">
                <!-- 檔案選單 -->
                <Menu Grid.Column="0" Background="Transparent">
                    <MenuItem Header="檔案" Foreground="{DynamicResource TextBrush}">
                        <MenuItem Header="開啟專案" Command="{Binding OpenProjectCommand}" IsEnabled="False" ToolTip.Tip="Phase 1 實作" />
                        <MenuItem Header="儲存專案" Command="{Binding SaveProjectCommand}" IsEnabled="False" ToolTip.Tip="Phase 1 實作" />
                    </MenuItem>
                </Menu>

                <!-- 載入範例 -->
                <Menu Grid.Column="1" Background="Transparent" Margin="8,0,0,0">
                    <MenuItem Header="載入範例▾" Foreground="{DynamicResource TextBrush}">
                        <MenuItem Header="NEMA17 馬達座" Command="{Binding LoadExampleCommand}" CommandParameter="nema17-mount" />
                        <MenuItem Header="針盒收納盒 5×10" Command="{Binding LoadExampleCommand}" CommandParameter="needle-box-5x10" />
                        <MenuItem Header="ESP32-CAM 外殼" Command="{Binding LoadExampleCommand}" CommandParameter="esp32cam-enclosure" />
                    </MenuItem>
                </Menu>

                <!-- 新增專案 -->
                <Button Grid.Column="2" Classes="tool" Content="新增專案" Command="{Binding NewProjectCommand}" Margin="8,0,0,0" />

                <!-- 重建 -->
                <Button Grid.Column="3" Classes="primary" Content="重建" Command="{Binding RebuildCommand}" Margin="8,0,0,0" />

                <!-- 右側動作 -->
                <Button Grid.Column="5" Classes="tool" Content="匯出 STEP" Command="{Binding ExportCommand}" CommandParameter="step" Margin="0,0,8,0" />
                <Button Grid.Column="6" Classes="tool" Content="匯出 STL" Command="{Binding ExportCommand}" CommandParameter="stl" Margin="0,0,8,0" />

                <!-- 收合右欄 -->
                <Button Grid.Column="8" Classes="tool" Content="⚙" Command="{Binding ToggleRightPanelCommand}" ToolTip.Tip="切換對話窗格" />
            </Grid>
        </Border>

        <!-- ═══ 主體三欄 ═══ -->
        <Grid Grid.Row="1" ColumnDefinitions="260,4,*,4,300">

            <!-- 左欄：特徵樹 + 參數面板 -->
            <Grid Grid.Column="0" RowDefinitions="*,4,*" Background="{DynamicResource MantleBrush}">
                <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Text="特徵樹" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="12,8,0,4" />
                        <TreeView Grid.Row="1" ItemsSource="{Binding FeatureTree}"
                                  SelectedItem="{Binding SelectedFeature}"
                                  Margin="8,0,8,8"
                                  Background="Transparent">
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource TextBrush}" />
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="1" Background="{DynamicResource BorderBrush}" ResizeDirection="Rows" />

                <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Text="參數面板" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="12,8,0,4" />
                        <ScrollViewer Grid.Row="1" Padding="8">
                            <ItemsControl ItemsSource="{Binding SelectedFeatureParameters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="100,*" Margin="0,2">
                                            <TextBlock Grid.Column="0" Text="{Binding Key}" Foreground="{DynamicResource SubtextBrush}" FontFamily="Consolas" FontSize="11" />
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" Background="{DynamicResource BorderBrush}" ResizeDirection="Columns" Width="4" />

            <!-- 中欄：3D Viewport（主角）-->
            <Grid Grid.Column="2" Background="{DynamicResource BaseBrush}">

                <!-- WebView -->
                <WebView x:Name="PART_Viewer" />

                <!-- 載入中提示 -->
                <TextBlock Text="3D 視窗載入中…" Foreground="{DynamicResource OverlayBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsVisible="{Binding !HasModel}" />

                <!-- 視角懸浮按鈕組（右上角） -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,12,0"
                        Background="{DynamicResource OverlayBgBrush}" CornerRadius="8" Padding="4">
                    <StackPanel Orientation="Vertical">
                        <Button Classes="view-btn" Content="等角" Command="{Binding SetViewCommand}" CommandParameter="iso" Margin="0,2" />
                        <Button Classes="view-btn" Content="正視" Command="{Binding SetViewCommand}" CommandParameter="front" Margin="0,2" />
                        <Button Classes="view-btn" Content="俯視" Command="{Binding SetViewCommand}" CommandParameter="top" Margin="0,2" />
                        <Button Classes="view-btn" Content="右視" Command="{Binding SetViewCommand}" CommandParameter="right" Margin="0,2" />
                    </StackPanel>
                </Border>

                <!-- 忙碌指示器（右下角） -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,12,12"
                        Background="{DynamicResource OverlayBgBrush}" CornerRadius="8" Padding="8"
                        IsVisible="{Binding IsBusy}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="重建中…" Foreground="{DynamicResource TextBrush}" FontSize="12" />
                        <ProgressBar IsIndeterminate="True" Width="40" Height="12" />
                    </StackPanel>
                </Border>

                <!-- 懸浮提示輸入列（底部置中） -->
                <Border HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,24"
                        Background="{DynamicResource OverlayBgBrush}" CornerRadius="12" Padding="4"
                        MinWidth="400" MaxWidth="600">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox x:Name="PART_PromptInput" Grid.Column="0" Text="{Binding InputText}" Watermark="描述設計需求…"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource TextBrush}"
                                 AcceptsReturn="True" MinHeight="36"
                                 CaretBrush="{DynamicResource AccentBrush}"
                                 TextWrapping="Wrap" />
                        <Button Grid.Column="1" Classes="primary" Content="送出"
                                Command="{Binding SendCommand}" VerticalAlignment="Center" Margin="4,0,0,0" />
                    </Grid>
                </Border>
            </Grid>

            <!-- 右欄：對話歷史（可收合） -->
            <GridSplitter Grid.Column="3" Background="{DynamicResource BorderBrush}" ResizeDirection="Columns" Width="4"
                          IsVisible="{Binding IsRightPanelVisible}" />

            <Border Grid.Column="4" Background="{DynamicResource MantleBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                    IsVisible="{Binding IsRightPanelVisible}">
                <Grid RowDefinitions="*,Auto">
                    <!-- 對話歷史 -->
                    <ScrollViewer Grid.Row="0" Padding="8" x:Name="PART_ChatScroll">
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="4">
                                        <!-- User 訊息 -->
                                        <Border Classes="msg-user" IsVisible="{Binding Kind, Converter={x:Static vm:MessageKindToVisibilityConverter.UserIsVisible}}">
                                            <TextBlock Text="{Binding Text}" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" />
                                        </Border>

                                        <!-- Assistant 訊息 -->
                                        <Border Classes="msg-assistant" IsVisible="{Binding Kind, Converter={x:Static vm:MessageKindToVisibilityConverter.AssistantIsVisible}}">
                                            <TextBlock Text="{Binding Text}" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" />
                                        </Border>

                                        <!-- Error 訊息 -->
                                        <Border Classes="msg-error" IsVisible="{Binding Kind, Converter={x:Static vm:MessageKindToVisibilityConverter.ErrorIsVisible}}">
                                            <TextBlock Text="{Binding Text}" Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap" />
                                        </Border>

                                        <!-- Plan 計畫卡片 -->
                                        <Border Classes="msg-plan" IsVisible="{Binding Kind, Converter={x:Static vm:MessageKindToVisibilityConverter.PlanIsVisible}}">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="建模計畫" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" />
                                                <TextBlock Text="{Binding Text}" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" />
                                                <!-- 步驟清單 -->
                                                <ItemsControl ItemsSource="{Binding Plan.Steps}" Margin="0,4,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Foreground="{DynamicResource SubtextBrush}" FontSize="12" TextWrapping="Wrap">
                                                                <Run Text="" />
                                                                <Run Text="{Binding Description}" />
                                                            </TextBlock>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <!-- 缺少資訊 -->
                                                <ItemsControl ItemsSource="{Binding Plan.MissingInfo}" IsVisible="{Binding Plan.MissingInfo.Count}" Margin="0,4,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Foreground="{DynamicResource WarningBrush}" FontSize="11" TextWrapping="Wrap"
                                                                       Text="{Binding}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <!-- 按鈕列 -->
                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                                                    <Button Classes="primary" Content="套用" Command="{Binding ApplyPlanCommand}" />
                                                    <Button Classes="tool" Content="取消" Command="{Binding CancelPlanCommand}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- LLM 狀態 -->
                    <TextBlock Grid.Row="1" Text="{Binding LlmStatus}" Foreground="{DynamicResource SubtextBrush}"
                               FontSize="11" Margin="8,4,8,8" />
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ 狀態列 ═══ -->
        <Border Grid.Row="2" Background="{DynamicResource CrustBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,4">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="{Binding WorkerStatus}" FontFamily="Consolas" FontSize="11"
                           Foreground="{DynamicResource SuccessBrush}"
                           IsVisible="{Binding IsWorkerConnected}" />
                <TextBlock Text="{Binding WorkerStatus}" FontFamily="Consolas" FontSize="11"
                           Foreground="{DynamicResource ErrorBrush}"
                           IsVisible="{Binding !IsWorkerConnected}" />
                <TextBlock Foreground="{DynamicResource SubtextBrush}" Text="{Binding LlmStatus}" FontFamily="Consolas" FontSize="11" />
                <TextBlock Foreground="{DynamicResource SubtextBrush}" Text="{Binding ModelInfoText}" FontFamily="Consolas" FontSize="11" />
            </StackPanel>
        </Border>
    </Grid>
</Window>