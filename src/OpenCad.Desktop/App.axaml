<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OpenCad.Desktop.App"
             RequestedThemeVariant="Light">

    <Application.Resources>
        <!-- ══ 暖色復古色票（WYGINS+ 參考）——沿用原有 key 名，所有 DynamicResource 自動生效 ══ -->
        <SolidColorBrush x:Key="BaseBrush"       Color="#F6EFDA"/>  <!-- 奶油底：視窗/視埠/輸入框 -->
        <SolidColorBrush x:Key="MantleBrush"     Color="#EFE6CC"/>  <!-- 面板：工具列/側欄 -->
        <SolidColorBrush x:Key="CrustBrush"      Color="#E7DCBE"/>  <!-- 狀態列底 -->
        <SolidColorBrush x:Key="SurfaceBrush"    Color="#E8DEC0"/>  <!-- 沙：助手氣泡/hover -->
        <SolidColorBrush x:Key="Surface1Brush"   Color="#C6A4D0"/>  <!-- 薰衣草紫：使用者氣泡 -->
        <SolidColorBrush x:Key="TextBrush"       Color="#2A2622"/>  <!-- 暖黑：主文字 -->
        <SolidColorBrush x:Key="SubtextBrush"    Color="#6E6353"/>  <!-- 暖棕灰：次文字 -->
        <SolidColorBrush x:Key="OverlayBrush"    Color="#A99F8C"/>
        <SolidColorBrush x:Key="AccentBrush"     Color="#D15E2A"/>  <!-- 赤陶橘：主強調 -->
        <SolidColorBrush x:Key="SuccessBrush"    Color="#5E6B2E"/>  <!-- 橄欖綠：通過/連線 -->
        <SolidColorBrush x:Key="WarningBrush"    Color="#8A6410"/>  <!-- 芥末（壓深以達 AA 對比）：警告 -->
        <SolidColorBrush x:Key="ErrorBrush"      Color="#B23B22"/>  <!-- 磚紅：錯誤 -->
        <SolidColorBrush x:Key="BorderBrush"     Color="#E2D6B2"/>  <!-- 暖分隔線 -->
        <SolidColorBrush x:Key="OverlayBgBrush"  Color="#CCF6EFDA"/>

        <!-- 分類色（供卡片/點綴/未來 CommandManager 使用） -->
        <SolidColorBrush x:Key="LavBrush"        Color="#C6A4D0"/>
        <SolidColorBrush x:Key="GoldBrush"       Color="#C6A02E"/>
        <SolidColorBrush x:Key="TerraBrush"      Color="#D15E2A"/>
        <SolidColorBrush x:Key="BlueBrush"       Color="#D6E6F5"/>
        <SolidColorBrush x:Key="SandBrush"       Color="#E8DEC0"/>
        <SolidColorBrush x:Key="CreamTextBrush"  Color="#FBF3E0"/>

        <!-- 字型：內文/標題用無襯線（中文乾淨）。DisplayFont 保留給拉丁/數字顯示或未來 .ttf——
             Georgia 無中文字符，故不套用於中文標題（方向 B）。 -->
        <FontFamily x:Key="DisplayFont">Georgia, Times New Roman, serif</FontFamily>
        <FontFamily x:Key="BodyFont">Segoe UI, Microsoft JhengHei UI, sans-serif</FontFamily>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />

        <!-- 視窗預設字型 -->
        <Style Selector="Window">
            <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
        </Style>

        <!-- 面板/卡片標題：乾淨無襯線粗體（中文適用；方向 B——襯線只保留給拉丁/數字） -->
        <Style Selector="TextBlock.h">
            <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>

        <!-- 工具列按鈕：透明底、hover 暖色、圓角 -->
        <Style Selector="Button.tool">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.tool:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        </Style>

        <!-- ══ 停用狀態：讓「不能按」的控制項一眼可辨，杜絕「看起來能按卻沒反應」 ══ -->
        <!-- Button.tool 原本無 disabled 樣式，停用後與正常態外觀相同，是「按了沒反應」的主因之一 -->
        <Style Selector="Button.tool:disabled">
            <Setter Property="Opacity" Value="0.38"/>
            <Setter Property="Cursor" Value="Arrow"/>
        </Style>
        <Style Selector="Button.card-act:disabled">
            <Setter Property="Opacity" Value="0.38"/>
        </Style>
        <Style Selector="Button.card-open:disabled">
            <Setter Property="Opacity" Value="0.55"/>
        </Style>
        <Style Selector="MenuItem:disabled">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>

        <!-- 主要動作按鈕：赤陶橘底、奶油字 -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource CreamTextBrush}"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#BB4E20"/>
            <Setter Property="Foreground" Value="{DynamicResource CreamTextBrush}"/>
        </Style>
        <Style Selector="Button.primary:disabled">
            <Setter Property="Opacity" Value="0.5"/>
        </Style>

        <!-- 懸浮視角按鈕 -->
        <Style Selector="Button.view-btn">
            <Setter Property="Background" Value="{DynamicResource OverlayBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinWidth" Value="44"/>
        </Style>
        <Style Selector="Button.view-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        </Style>

        <!-- 訊息氣泡：使用者紫、助手沙、大圓角帶尾巴 -->
        <Style Selector="Border.msg-user">
            <Setter Property="Background" Value="{DynamicResource Surface1Brush}"/>
            <Setter Property="CornerRadius" Value="14,14,4,14"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="MaxWidth" Value="260"/>
        </Style>
        <Style Selector="Border.msg-assistant">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="14,14,14,4"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="MaxWidth" Value="260"/>
        </Style>
        <Style Selector="Border.msg-error">
            <Setter Property="Background" Value="#1FB23B22"/>
            <Setter Property="CornerRadius" Value="6,14,14,6"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
            <Setter Property="BorderThickness" Value="4,0,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="MaxWidth" Value="260"/>
        </Style>
        <!-- 啟動首頁專案卡片 -->
        <Style Selector="Border.proj-card">
            <Setter Property="Background" Value="{DynamicResource MantleBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="212"/>
            <Setter Property="Margin" Value="9"/>
        </Style>
        <Style Selector="Border.proj-card:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        </Style>
        <!-- 卡片開啟按鈕：整塊可點、透明底、hover 微亮 -->
        <Style Selector="Button.card-open">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.card-open:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        </Style>
        <!-- 卡片小動作按鈕 -->
        <Style Selector="Button.card-act">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.card-act:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        </Style>

        <!-- 計畫/差異卡片：奶油底、赤陶橘左緣 -->
        <Style Selector="Border.msg-plan">
            <Setter Property="Background" Value="{DynamicResource MantleBrush}"/>
            <Setter Property="CornerRadius" Value="6,14,14,14"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="4,0,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
    </Application.Styles>
</Application>
